{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    "AGENTS.md"
  ],
  "provider": {
    "twentyfirst": {
      "options": {
        "apiKey": "${TWENTYFIRST_API_KEY}"
      },
      "models": {
        "claude-sonnet-4-6": {},
        "claude-opus-4-6": {}
      }
    },
    "google": {
      "options": {
        "apiKey": "${GOOGLE_GENERATIVE_AI_API_KEY}"
      }
    }
  },
  "agent": {
    "claude-opus-4-5": {
      "model": "twentyfirst/claude-opus-4-6",
      "mode": "subagent",
      "description": "Deep reasoning for structural analysis, debugging, architecture, and code review",
      "steps": 30
    },
    "claude-sonnet-4-5": {
      "model": "twentyfirst/claude-sonnet-4-6",
      "mode": "subagent",
      "description": "Precision code generation for UI components, features, algorithms, and production-ready assets",
      "steps": 30
    },
    "gemini-3-pro": {
      "model": "google/gemini-3-pro",
      "mode": "subagent",
      "description": "Fast broad analysis for codebase exploration, multi-file scanning, and research tasks",
      "steps": 20
    }
  },
  "mcp": {
    "stitch": {
      "type": "remote",
      "url": "https://stitch.googleapis.com/mcp",
      "enabled": true,
      "headers": {
        "X-Goog-Api-Key": "${GOOGLE_GENERATIVE_AI_API_KEY}"
      }
    },
    "shadcn": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "shadcn@latest",
        "mcp"
      ],
      "enabled": true
    },
    "claude-code": {
      "type": "local",
      "command": [
        "C:\\Users\\546493.UNIMAS\\.local\\bin\\uvx.exe",
        "--from",
        "mcp-claude-code",
        "claudecode",
        "--allow-path",
        "D:\\GITHUB\\TC",
        "--project",
        "D:\\GITHUB\\TC"
      ],
      "enabled": true
    }
  }
}
